DATABASE_URL=postgres://customer_service:customer_service_dev@localhost:5432/customer_service
REDIS_URL=redis://localhost:6379
AUTH_JWT_SECRET=0123456789abcdef0123456789abcdef
PORT=8080
APP_ENVIRONMENT=development
POSTGRES_DB=customer_service
POSTGRES_USER=customer_service
POSTGRES_PASSWORD=customer_service_dev
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# AI Provider Abstraction
# Generate with: openssl rand -base64 32
APP_AI_KEY_ENCRYPTION_KEY=
# Optional per-provider base URL overrides (useful for testing or proxies):
# APP_AI_OPENAI_BASE_URL=
# APP_AI_ANTHROPIC_BASE_URL=
# APP_AI_GEMINI_BASE_URL=

# Object Storage (S3-compatible) — Knowledge Base
# Set all six or none; partial configuration will cause the server to refuse to start.
# The bucket named by APP_S3_BUCKET must exist before first upload (the app does not create it).
# With no APP_S3_* vars set, the server falls back to ephemeral in-memory storage.
# APP_S3_ENDPOINT=http://localhost:9000
# APP_S3_REGION=us-east-1
# APP_S3_BUCKET=
# APP_S3_ACCESS_KEY_ID=
# APP_S3_SECRET_ACCESS_KEY=
# APP_S3_FORCE_PATH_STYLE=true    # defaults to true; required for MinIO

